# ============================================================
# Demo-режим: всё локально, без интернета, без корп-доступов.
#
# Скопируй этот файл в .env (либо: cp .env.demo .env), стартани
# ./run.sh. Mock-LLM и mock-эмбеддинги дадут детерминированные
# ответы, а FTS5 обеспечит работающий полнотекстовый поиск.
# ============================================================

APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Локальные mock-адаптеры — никаких внешних HTTP-вызовов ---
LLM_PROVIDER=mock
EMBEDDINGS_PROVIDER=mock

# --- БД: SQLite в файле, FTS5 встроен, sqlite_vec может не подгрузиться
#     на python.org-сборке macOS — это нормально, есть graceful fallback.
DB_BACKEND=sqlite
DB_SQLITE_PATH=./data/app.db

# --- Безопасность: CSRF включён, чтобы UI ходил через /api/csrf-токен
#     (как в проде); можно отключить для голого curl-тестирования.
SECURITY_CSRF_ENABLED=true

# --- Алёрты по умолчанию выключены; включишь, когда настроишь webhook
ALERTS_ENABLED=false
