# ============================================================
# Общие
# ============================================================
APP_ENV=local                       # local | dev | prod
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                  # console | json (json для prod)
CORS_ALLOWED_ORIGINS=http://localhost:8000

# ============================================================
# Database
# ============================================================
# DB_BACKEND: sqlite | postgres
DB_BACKEND=sqlite

# Для SQLite
DB_SQLITE_PATH=./data/app.db

# Для Postgres
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_DB=support_assistant
DB_POSTGRES_USER=sa_user
DB_POSTGRES_PASSWORD=change_me
DB_POSTGRES_POOL_SIZE=10
DB_POSTGRES_MAX_OVERFLOW=5

# ============================================================
# LLM
# ============================================================
# LLM_PROVIDER: gigachat | yandexgpt | openai_compatible | mock
LLM_PROVIDER=mock
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_BUDGET_PER_USER_DAILY=300

# --- GigaChat ---
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# Готовый Bearer-токен (опционально). Если задан — OAuth не выполняется.
# Удобно для тестового стенда / ad-hoc проверок / внешне выпущенного токена.
GIGACHAT_ACCESS_TOKEN=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_CORP
GIGACHAT_MODEL_PRIMARY=GigaChat-Max
GIGACHAT_MODEL_JUDGE=GigaChat-Max
GIGACHAT_VERIFY_SSL=false
GIGACHAT_CA_BUNDLE_PATH=

# --- YandexGPT (опционально) ---
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL_URI=gpt://b1g.../yandexgpt/latest

# --- OpenAI-compatible (для локальной модели/dev) ---
OPENAI_BASE_URL=http://localhost:8080/v1
OPENAI_API_KEY=dummy
OPENAI_MODEL=Qwen2.5-32B-Instruct

# ============================================================
# Embeddings
# ============================================================
# EMBEDDINGS_PROVIDER: local | api | mock
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDINGS_CACHE_DIR=./models/embeddings
EMBEDDINGS_DEVICE=cpu               # cpu | cuda | mps
EMBEDDINGS_BATCH_SIZE=32
EMBEDDINGS_DIMENSION=1024
EMBEDDINGS_API_URL=
EMBEDDINGS_API_KEY=

# ============================================================
# Vector Store
# ============================================================
# VECTOR_BACKEND: sqlite_vec | pgvector | "" (авто по DB_BACKEND)
VECTOR_BACKEND=
VECTOR_SEARCH_TOP_K=30
TEXT_SEARCH_TOP_K=30

# ============================================================
# Retrieval / Reranking
# ============================================================
RETRIEVAL_RRF_K=60
RETRIEVAL_FINAL_TOP_K=8
RERANKER_ENABLED=true
RERANKER_TYPE=llm                   # llm | cross_encoder | none
RERANKER_MODEL=

# ============================================================
# PII
# ============================================================
PII_ENABLED=true
PII_NER_ENABLED=true
PII_STRICT_MODE=true
PII_AUDIT_SAMPLE_RATE=0.1

# ============================================================
# Ingest
# ============================================================
INGEST_BATCH_SIZE=50
INGEST_LLM_CONCURRENCY=4
INGEST_MAX_TICKET_AGE_DAYS=540

# ============================================================
# Безопасность
# ============================================================
SECURITY_RATE_LIMIT_PER_MINUTE=120
SECURITY_MAX_BODY_BYTES=10485760
SECURITY_CSRF_ENABLED=true
SECURITY_ALLOWED_LLM_HOSTS=

# ============================================================
# Frontend
# ============================================================
UI_DEFAULT_THEME=auto               # dark | light | auto
UI_SHOW_DEBUG_PANEL=false
